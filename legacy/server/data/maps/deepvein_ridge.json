  "landmarks": [
    {
      "id": "lm_deepvein_return_pier",
      "name": "回渡石坪",
      "x": 56,
      "y": 30,
      "desc": "厚脉岭最外层唯一还能站稳脚跟的石坪，背后就是栖真渡，往前一步便是整座山体压下来的采脉路。"
    },
    {
      "id": "lm_deepvein_foothill_pocket",
      "name": "山脚采脉口",
      "x": 47,
      "y": 26,
      "desc": "这里不是露天矿场，只是山脚被凿穿后露出来的一口浅袋。站在这儿就能看见前面的路其实全埋在矿里。"
    },
    {
      "id": "lm_deepvein_slant_cut",
      "name": "裂脉斜沟",
      "x": 44,
      "y": 29,
      "desc": "一道斜着吃进山体的旧掘线，左右全是硬矿和断石，能往里走的缝只够一层层抠开。"
    },
    {
      "id": "lm_deepvein_fall_choke",
      "name": "坠石狭喉",
      "x": 36,
      "y": 25,
      "desc": "断层把中段掐成一截石喉，挖开一块才多一格，怪物也常卡在这些刚露出来的小口袋里。"
    },
    {
      "id": "lm_deepvein_stele_slope",
      "name": "负碑缓坡",
      "x": 30,
      "y": 18,
      "desc": "坡道上残着压脉旧碑和被砸进山里的台阶，越往上掘，越像整座山在往人背上落。"
    },
    {
      "id": "lm_deepvein_pillar_highland",
      "name": "石柱高坪",
      "x": 18,
      "y": 29,
      "desc": "这一层终于稍微开阔一些，但视野全被石柱和残矿切碎，真正能站人的地方反而比狭道更零散。"
    },
    {
      "id": "lm_deepvein_guizang_gate",
      "name": "镇岳地关",
      "x": 10,
      "y": 8,
      "desc": "最深处的石府前庭只剩一道被强行压住的旧门，门后还连着更深的地脉缝，就是归藏脉窟外围。"
    }
  ],
  "npcs": [
    {
      "id": "npc_deepvein_pick_foreman",
      "name": "开脉把头·石沉",
      "x": 57,
      "y": 29,
      "char": "矿",
      "color": "#cbb08a",
      "dialogue": "厚脉岭没有现成的路。你若只想着往前冲，不是先被石头卡死，就是先把自己挖空。先认哪块该开，哪块该绕，再谈往里走。",
      "role": "quest_hint",
      "shopItems": [],
      "quests": []
    },
    {
      "id": "npc_deepvein_old_steward",
      "name": "守碑老修·陶埴",
      "x": 21,
      "y": 33,
      "char": "碑",
      "color": "#b89f7d",
      "dialogue": "土行不是叫你变慢，是叫你扛得住。真到了镇岳前庭，能不能再往里走，看的不是你打多狠，是你这口气海还能不能继续承压。",
      "role": "lore",
      "shopItems": [],
      "quests": []
    }
  ],
