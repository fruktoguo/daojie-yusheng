  "landmarks": [
    {
      "id": "lm_cleft_tomb_front_main",
      "name": "断兵冢前",
      "x": 16,
      "y": 9,
      "desc": "这一段已经能看见断兵冢外缘，地上不是碎兵散落，而是整圈被埋进地里的断锋和黑铁骨架。主路再也不宽，走得越深越像被整片锋压往前推。"
    },
    {
      "id": "lm_cleft_tomb_front_ring",
      "name": "埋锋环",
      "x": 19,
      "y": 8,
      "desc": "冢前外围像环带一样埋着成片断剑堆，表层风化得快，但一敲就能听见里面还有整段铁芯。这一圈既是障碍，也像一圈被掩住的矿带。"
    },
    {
      "id": "lm_cleft_tomb_front_ridge",
      "name": "玄铁脊",
      "x": 12,
      "y": 15,
      "desc": "下侧这一脊全是被压出来的黑铁露头，夹在断刃和碎岩里，像冢口下方把整片旧兵骨都顶了出来。"
    },
    {
      "id": "lm_cleft_tomb_front_gate",
      "name": "冢门前沿",
      "x": 4,
      "y": 9,
      "desc": "再往前就是断兵冢口的最后前沿。这里路面已经收成只剩一口能硬顶的窄道，走到这里的人，下一步就该进首领区了。"
    }
  ],
