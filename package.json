{
  "name": "daojie-yusheng",
  "private": true,
  "scripts": {
    "build": "pnpm run build:next",
    "build:next": "pnpm run build:config-editor && pnpm run build:client-next && pnpm run build:server-next",
    "build:config-editor": "pnpm --filter @mud/config-editor build",
    "build:server-next": "pnpm --filter @mud/server-next compile",
    "check:item-sources": "node scripts/check-item-sources.mjs",
    "sync:tutorial-mechanics": "node scripts/sync-tutorial-mechanics.mjs",
    "legacy:sync:value-reports": "pnpm --filter @mud/server exec node dist/tools/export-value-reports.js",
    "generate:editor-catalog": "node scripts/generate-editor-catalog.mjs --client=client-next --shared=shared-next",
    "generate:editor-catalog:next": "node scripts/generate-editor-catalog.mjs --client=client-next --shared=shared-next",
    "legacy:generate:editor-catalog": "node scripts/generate-editor-catalog.mjs --client=client --shared=shared",
    "organize:techniques": "node scripts/organize-techniques.mjs --write",
    "sync:qi-items": "node scripts/sync-qi-item-sources.mjs",
    "sync:technique-books": "node scripts/sync-technique-books.mjs",
    "dev:client": "pnpm --filter @mud/client-next dev",
    "dev:client-next": "pnpm --filter @mud/client-next dev",
    "legacy:dev:client": "pnpm --filter @mud/client dev",
    "dev:server": "pnpm --filter @mud/server-next start:dev",
    "legacy:dev:server": "pnpm --filter @mud/server start:dev",
    "start:server": "pnpm --filter @mud/server-next start",
    "legacy:start:server": "pnpm --filter @mud/server start",
    "legacy:start:backup-worker": "pnpm --filter @mud/server start:backup-worker",
    "dev:server-next": "pnpm --filter @mud/server-next start:dev",
    "start:server-next": "pnpm --filter @mud/server-next start",
    "build:shared-next": "pnpm --filter @mud/shared-next build",
    "build:client-next": "pnpm --filter @mud/client-next build",
    "verify:replace-ready": "node scripts/replace-ready.js",
    "verify:replace-ready:acceptance": "node scripts/replace-ready-acceptance.js",
    "verify:replace-ready:doctor": "node scripts/replace-ready-doctor.js",
    "verify:replace-ready:full": "node scripts/replace-ready-full.js",
    "verify:replace-ready:proof:with-db": "node scripts/replace-ready-proof-with-db.js",
    "verify:replace-ready:shadow:destructive": "node scripts/replace-ready-shadow-destructive.js",
    "verify:replace-ready:with-db": "node scripts/replace-ready-with-db.js",
    "verify:replace-ready:shadow": "node scripts/replace-ready-shadow.js",
    "verify:server-next": "node scripts/server-next-verify.js",
    "verify:server-next:acceptance": "node scripts/server-next-verify-acceptance.js",
    "verify:server-next:doctor": "node scripts/server-next-verify-doctor.js",
    "verify:server-next:full": "node scripts/server-next-verify-full.js",
    "verify:server-next:proof:with-db": "node scripts/server-next-verify-proof-with-db.js",
    "verify:server-next:shadow:destructive": "node scripts/server-next-verify-shadow-destructive.js",
    "verify:server-next:with-db": "node scripts/server-next-verify-with-db.js",
    "verify:server-next:shadow": "node scripts/server-next-verify-shadow.js",
    "proof:next-client-shared-no-legacy-source": "node scripts/prove-next-client-shared-no-legacy-source.js",
    "proof:next-client-s2c-consumption": "node scripts/prove-next-client-s2c-consumption.js",
    "audit:server-next-protocol": "pnpm --filter @mud/server-next audit:next-protocol",
    "audit:server-next-boundaries": "pnpm --filter @mud/server-next audit:legacy-boundaries",
    "report:alchemy-material-power": "node scripts/report-alchemy-material-power.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript-language-server": "^5.1.3",
    "vscode-langservers-extracted": "^4.10.0",
    "yaml-language-server": "^1.21.0"
  }
