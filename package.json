{
  "name": "daojie-yusheng",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "check:item-sources": "node scripts/check-item-sources.mjs",
    "generate:editor-catalog": "node scripts/generate-editor-catalog.mjs --client=client --shared=shared",
    "generate:editor-catalog:next": "node scripts/generate-editor-catalog.mjs --client=client-next --shared=shared-next",
    "organize:techniques": "node scripts/organize-techniques.mjs --write",
    "sync:qi-items": "node scripts/sync-qi-item-sources.mjs",
    "sync:technique-books": "node scripts/sync-technique-books.mjs",
    "dev:client": "pnpm --filter @mud/client dev",
    "dev:client-next": "pnpm --filter @mud/client-next dev",
    "dev:server": "pnpm --filter @mud/server start:dev",
    "start:server": "pnpm --filter @mud/server start",
    "start:backup-worker": "pnpm --filter @mud/server start:backup-worker",
    "dev:server-next": "pnpm --filter @mud/server-next start:dev",
    "start:server-next": "pnpm --filter @mud/server-next start",
    "build:shared-next": "pnpm --filter @mud/shared-next build",
    "build:client-next": "pnpm --filter @mud/client-next build",
    "verify:server-next": "node scripts/server-next-verify.js",
    "verify:server-next:with-db": "node scripts/server-next-verify-with-db.js",
    "verify:server-next:shadow": "node scripts/server-next-verify-shadow.js",
    "audit:server-next-protocol": "pnpm --filter @mud/server-next audit:next-protocol"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript-language-server": "^5.1.3",
    "vscode-langservers-extracted": "^4.10.0",
    "yaml-language-server": "^1.21.0"
  }
}
