  "landmarks": [
    {
      "id": "lm_darksoil_entry",
      "name": "落入洞厅",
      "x": 14,
      "y": 6,
      "desc": "从焚木荒台塌陷处坠入后的第一座洞厅。北侧残阶嵌在岩壁里，洞顶有微光透下，土行灵压沉重得让人呼吸困难。"
    },
    {
      "id": "lm_darksoil_vein_hall",
      "name": "矿脉厅",
      "x": 10,
      "y": 25,
      "desc": "西侧主洞厅，四壁嵌满玄铁矿脉与零星灵石。穿山甲兽借矿脉走势挖出条条暗道，是补给土行材料的核心区域。"
    },
    {
      "id": "lm_darksoil_mushroom_cave",
      "name": "蘑菇洞",
      "x": 44,
      "y": 8,
      "desc": "东北潮湿支洞，地面尽是松软泥潭与浅水沼泽，木腐与土腥气混杂。毒菇蟾卧于泥心，吞吐着微弱的木土双行灵气。"
    },
    {
      "id": "lm_darksoil_central_hall",
      "name": "中央大厅",
      "x": 28,
      "y": 25,
      "desc": "深渊网络的交通枢纽，多条通道在此汇合。中央隆起的土丘平台是岩脊蜈蚣的猎食高地，从这里可分赴地脉泉、深渊底与封印石室。"
    },
    {
      "id": "lm_darksoil_dragon_lair",
      "name": "地脉泉",
      "x": 12,
      "y": 42,
      "desc": "西南底层的环形泉水洞窟，中央高台被深泉环绕，泉水呈玄黑色翻涌不息。玄壤地龙盘踞高台，借泉脉吞吐土行灵气。"
    },
    {
      "id": "lm_darksoil_seal_chamber",
      "name": "封印石室",
      "x": 47,
      "y": 40,
      "desc": "东南方一座由远古修士手工凿就的方形石室，四壁刻满模糊的封印阵纹。五行噬脉兽被困于其中，灵气在阵纹间被反复抽离再注回。"
    },
    {
      "id": "lm_darksoil_abyss_floor",
      "name": "深渊裂缝",
      "x": 28,
      "y": 50,
      "desc": "整张地图最深处的小空间，地面有一道被封缄的裂缝向下延伸。隐约可见更深层的封印痕迹。（金丹期入口预留，当前仅作描述。）"
    }
  ],
  "npcs": [
    {
      "id": "npc_darksoil_veteran",
      "name": "老猎手·土行孙",
      "x": 13,
      "y": 7,
      "char": "猎",
      "color": "#9a8060",
      "dialogue": "这里是筑基期的尽头了。入口厅往西南能绕进矿脉厅，往东北是泥沼蘑菇洞，两边最后都汇到中央大厅。再往下，西南是地脉泉那条地龙的窝，东南是封印石室，正南还有一道被封死的深裂口。根基不够硬就别硬碰 Boss，强行突破只会走火入魔。",
      "role": "warning",
      "shopItems": [],
      "quests": []
    }
