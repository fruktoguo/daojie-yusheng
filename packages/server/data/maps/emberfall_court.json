  "landmarks": [
    {
      "id": "lm_ember_return_steps",
      "name": "回渡火阶",
      "x": 28,
      "y": 3,
      "desc": "赤陨庭最上层还算稳的落脚口，往后一步就是栖真渡，往前一步就是整座古炉的下沉火路。"
    },
    {
      "id": "lm_ember_outer_court",
      "name": "焦土外庭",
      "x": 22,
      "y": 9,
      "desc": "最外圈的灰地和断坡还留着些退路，但热浪已经开始顺着坑壁往里卷，站久了就会明白这里不是普通荒地。"
    },
    {
      "id": "lm_ember_heat_terrace",
      "name": "断层热堤",
      "x": 41,
      "y": 17,
      "desc": "第一层真正贴着熔裂带走的台路，旁边就是没熄干净的火脉，整条线既窄又躁。"
    },
    {
      "id": "lm_ember_turn_corridor",
      "name": "陨火回廊",
      "x": 24,
      "y": 22,
      "desc": "路线从这里开始明显回折，陨火残块和断墙把视线切碎，逼着人一边躲火一边贴路推进。"
    },
    {
      "id": "lm_ember_cracked_gallery",
      "name": "熔裂长廊",
      "x": 28,
      "y": 30,
      "desc": "长廊四周全是翻着热光的裂带，再往里走，已经没有“外庭”这种说法，只剩古炉本身的压力。"
    },
    {
      "id": "lm_ember_inner_yard",
      "name": "炉渣内院",
      "x": 24,
      "y": 39,
      "desc": "这里原本像是守炉人的内院，如今只剩炉渣、焦墙和没冷透的灰带，越静反而越像火还在下面喘。"
    },
    {
      "id": "lm_ember_guizang_gap",
      "name": "归藏炉隙",
      "x": 40,
      "y": 42,
      "desc": "炉壁最深处裂开了一道向下的旧隙，热气沿着缝往更深处倒灌，穿过去就是归藏脉窟外围。"
    }
  ],
  "npcs": [
    {
      "id": "npc_ember_forge_drifter",
      "name": "淬火散修·厉尘",
      "x": 34,
      "y": 9,
      "char": "修",
      "color": "#f0b36a",
      "dialogue": "赤陨庭不是看谁更敢冲，是看谁敢把那口躁火压进经脉里还不炸。你若只会贪快，走不到第二层就要自己先乱。",
      "role": "quest_hint",
      "shopItems": [],
      "quests": []
    },
    {
