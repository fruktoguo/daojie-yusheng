  "landmarks": [
    {
      "id": "lm_cleft_tomb_mouth_main",
      "name": "断兵冢口",
      "x": 18,
      "y": 9,
      "desc": "冢口只剩半圈残阵和一片硬到发脆的镇墓坪。所有残兵、断锋和黑铁都在这里被压成最后一道正面对撞的窄路，能走到这里，裂锋原就算基本走穿了。"
    },
    {
      "id": "lm_cleft_tomb_mouth_half_wall",
      "name": "残阵半壁",
      "x": 20,
      "y": 6,
      "desc": "上半圈石壁原本是镇墓残阵的一部分，如今只剩一道歪着嵌进崖里的半壁。风过这里会带出整片金行回响，像旧阵还在咬着不散。"
    },
    {
      "id": "lm_cleft_tomb_mouth_yard",
      "name": "镇墓坪",
      "x": 11,
      "y": 14,
      "desc": "冢前这一小块平地看着平整，其实地底全是黑铁脊和埋锋。站稳脚以后会发现，整块地都是硬的，像专门给最后一战留出来的撞阵坪。"
    },
    {
      "id": "lm_cleft_tomb_mouth_gate",
      "name": "归藏锋门",
      "x": 3,
      "y": 9,
      "desc": "冢口后侧嵌着一扇半埋地的锋门，门后不再是纯金行地带，而是归藏脉窟外围的混行路。"
    },
    {
      "id": "lm_cleft_tomb_front_main",
      "name": "断兵冢前",
      "x": 48,
      "y": 9,
      "desc": "这一段已经能看见断兵冢外缘，地上不是碎兵散落，而是整圈被埋进地里的断锋和黑铁骨架。主路再也不宽，走得越深越像被整片锋压往前推。"
    },
    {
      "id": "lm_cleft_tomb_front_ring",
      "name": "埋锋环",
      "x": 51,
      "y": 8,
      "desc": "冢前外围像环带一样埋着成片断剑堆，表层风化得快，但一敲就能听见里面还有整段铁芯。这一圈既是障碍，也像一圈被掩住的矿带。"
    },
    {
      "id": "lm_cleft_tomb_front_ridge",
      "name": "玄铁脊",
      "x": 44,
      "y": 14,
      "desc": "下侧这一脊全是被压出来的黑铁露头，夹在断刃和碎岩里，像冢口下方把整片旧兵骨都顶了出来。"
    },
    {
      "id": "lm_cleft_tomb_front_gate",
      "name": "冢门前沿",
      "x": 36,
      "y": 9,
      "desc": "再往前就是断兵冢口的最后前沿。这里路面已经收成只剩一口能硬顶的窄道，走到这里的人，下一步就该进首领区了。"
    },
    {
      "id": "lm_cleft_plateau_main",
      "name": "断阵台地",
      "x": 81,
      "y": 8,
      "desc": "这里原本是一整块压阵台面，如今被锋痕切成几段高低断层。再往前就不能只顾着直冲，而是得学会在卡口里硬顶。"
    },
    {
      "id": "lm_cleft_plateau_slot",
      "name": "裂阵槽",
      "x": 86,
      "y": 8,
      "desc": "直道的硬势在这里被阵槽截断，想继续推进，必须先钻过这道被削开的窄口。"
    },
    {
      "id": "lm_cleft_plateau_pins",
      "name": "断旗钉台",
      "x": 80,
      "y": 6,
      "desc": "台边钉满断旗杆和残剑堆，风一吹就会一起震响，像整片旧阵还在死撑最后一口气。"
    },
    {
      "id": "lm_cleft_plateau_drop",
      "name": "沉锋坠口",
      "x": 81,
      "y": 10,
      "desc": "中台往下折的这一口全是碎锋和落石，站不稳的人会在这里被金行压力生生压退。"
    },
    {
      "id": "lm_cleft_plateau_next",
      "name": "断兵冢前路",
      "x": 66,
      "y": 10,
      "desc": "台地到这里开始收成前窄后死的窄口，再过去就是更狠、更近首领压力的断兵冢前。"
    },
    {
      "id": "lm_cleft_straightway_main",
      "name": "金砂直道",
      "x": 111,
      "y": 9,
      "desc": "整段主路被金砂和旧锋痕压成一条笔直硬道，越往里越能感觉到这里逼人只许正推。"
    },
    {
      "id": "lm_cleft_straightway_upper_cut",
      "name": "上壁锋痕",
      "x": 113,
      "y": 6,
      "desc": "上壁留着整排斩痕，砂风一卷，断刃会顺着崖口成线扫下来。"
    },
    {
      "id": "lm_cleft_straightway_lower_cut",
      "name": "下坡砂坑",
      "x": 108,
      "y": 11,
      "desc": "下坡全是被砂风刮开的浅坑，残枪碎片埋在里面，稍一停步就容易被拖慢节奏。"
    },
    {
      "id": "lm_cleft_straightway_next_gate",
      "name": "断阵地口",
      "x": 98,
      "y": 9,
      "desc": "直道尽头开始收紧，再往前就不是单纯直顶，而是要在断台和卡口里硬撞过去。"
    },
    {
      "id": "lm_cleft_slope_main",
      "name": "碎兵坡",
      "x": 139,
      "y": 9,
      "desc": "坡面不陡，但残兵碎甲把整片地切成一块块钝坑，真正能稳步推进的只有中间这条硬路。"
    },
    {
      "id": "lm_cleft_slope_upper_pit",
      "name": "裂盾坑",
      "x": 136,
      "y": 8,
      "desc": "上坡这一带埋着最多裂盾和断矛，金砂一吹，碎锋会像草叶一样乱卷。"
    },
    {
      "id": "lm_cleft_slope_lower_pit",
      "name": "断枪坑",
      "x": 136,
      "y": 13,
      "desc": "下坡坑里压着一层层断枪残杆，脚下一陷，人就很容易被怪从正面顶住。"
    },
    {
      "id": "lm_cleft_slope_next_mouth",
      "name": "金砂道口",
      "x": 128,
      "y": 9,
      "desc": "再往前就是更直、更硬的金砂主道，碎兵坡只是让人先学会怎么顶着金行压力往前走。"
    },
    {
      "id": "lm_cleft_entry_return_array",
      "name": "回渡残阵",
      "x": 172,
      "y": 9,
      "desc": "残阵靠补缀阵钉和碎甲上的金纹硬撑着，一旦顶不住裂锋原的正面压力，退路就只剩这里。"
    },
    {
      "id": "lm_cleft_entry_slope_mouth",
      "name": "碎兵坡口",
      "x": 157,
      "y": 9,
      "desc": "主路一离开残阵就斜着压进坡口，地上全是断枪、裂盾和被砂风磨白的兵骨。"
    }
