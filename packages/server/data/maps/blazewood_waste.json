  "landmarks": [
    {
      "id": "lm_blazewood_entry",
      "name": "焦土平台",
      "x": 5,
      "y": 22,
      "desc": "从冰火交界处踏出，迎面便是灼热的焦风。脚下是被反复烧灼过的板结焦土，零星焦木残桩仍在缓慢燃烧。台面相对平整，是荒台西端的最后落脚点。"
    },
    {
      "id": "lm_blazewood_first_rift",
      "name": "第一裂缝",
      "x": 19,
      "y": 22,
      "desc": "纵贯南北的第一道地火裂缝，岩浆在缝底缓缓流动。北、中、南三处可见窄桥跨缝而立，桥位错开，须上下迂回。"
    },
    {
      "id": "lm_blazewood_burning_grove",
      "name": "焚林",
      "x": 33,
      "y": 22,
      "desc": "中央荒原最密的焦木林段。残桩成片燃烧，视线在烟焰中扭曲，赤焰蜂与焦木蜥常借林荫包抄过往修士。"
    },
    {
      "id": "lm_blazewood_second_rift",
      "name": "第二裂缝",
      "x": 47,
      "y": 22,
      "desc": "通往焚心台的最后一道熔池屏障，唯有中线一座三步宽的宽桥可过。桥两侧的熔池灼浪上腾，过桥时连袖摆都会被烤出焦痕。"
    },
    {
      "id": "lm_blazewood_boss_arena",
      "name": "焚心台",
      "x": 56,
      "y": 22,
      "desc": "荒台最东端的天然石台，台面被高温烧得通红，焚木妖王盘踞于此。台体周围是环形熔池，焦岩柱嶙峋错落，灼热的火木双行灵力在台面上空交织成旋涡。"
    }
  ],
  "npcs": [
    {
      "id": "npc_blazewood_hermit",
      "name": "焦原隐修·灰烬",
      "x": 6,
      "y": 21,
      "char": "隐",
      "color": "#c49060",
      "dialogue": "这片荒台被两道地火裂缝切成三段——第一道有北、中、南三座窄桥，桥位都错开了，得上下迂回。第二道只剩中线一座宽桥通往焚心台，过去就是焚木妖王的地盘。火木双行的妖兽又硬又能回血，没准备好压制手段，别贸然过第二道桥。",
