  "landmarks": [
    {
      "id": "lm_guizang_return_gate",
      "name": "归藏回渡口",
      "x": 60,
      "y": 32,
      "desc": "五行深处的入口全被压进这一小截外口，背后的回渡阵还能把人送回栖真渡，但门前的断崖已经把直路掐成了折口。"
    },
    {
      "id": "lm_guizang_reflux_corridor",
      "name": "乱流甬道",
      "x": 48,
      "y": 13,
      "desc": "从外口往里第一段就是细长混脉甬道，金刃、木结、冷流和熔点轮番贴脸，想稳着推进只能一段一段换气。"
    },
    {
      "id": "lm_guizang_outer_ring",
      "name": "偏脉外环",
      "x": 42,
      "y": 18,
      "desc": "第一圈完整大环路就在这里开始成形。每一段看似有主属性，实际上都被别的偏炁从侧��拧进来，走久了会发现没有一块地是真正单行的。"
    },
    {
      "id": "lm_guizang_bent_gallery",
      "name": "错流折廊",
      "x": 34,
      "y": 24,
      "desc": "外环之后不再给你直切心区的路，折廊每一次转向都像被别的炁硬生生横插一刀，方向感和节奏感都会在这里被打碎。"
    },
    {
      "id": "lm_guizang_heart_court",
      "name": "归藏心庭",
      "x": 25,
      "y": 30,
      "desc": "中层第一次稍微放开的平台，却不是给人喘气的地方。五炁残流在这里彼此顶撞，站位稍乱就会被不同偏压轮着撕。"
    },
    {
      "id": "lm_guizang_pressure_steps",
      "name": "压基前阶",
      "x": 21,
      "y": 40,
      "desc": "再往里走，能站人的线已经越来越像旧阵留下来的边骨。到这一步，整张图不再是洞窟，而像一座快要塌掉的立基场。"
    },
    {
      "id": "lm_guizang_core",
      "name": "压基古阵核",
      "x": 30,
      "y": 31,
      "desc": "阵核没有大殿，只有一块还在硬压五炁的歪阵面。能走到这里，碰上的就不是哪一行的尽头，而是练气期对混行承压的最终考题。"
    },
    {
      "id": "lm_guizang_heaven_ladder_gate",
      "name": "天梯接引阶",
      "x": 32,
      "y": 31,
      "desc": "道基古阵旁的石阶只露出最下几级，真正的长阶被道压藏在阵后。半步筑基者可由此踏上天梯。"
    }
  ],
