  "landmarks": [
    {
      "id": "lm_qizhen_yaji",
      "name": "压基坪",
      "x": 29,
      "y": 10,
      "desc": "北面的接引石台不是平铺出来的，而是一层层垫高、补缀、再用旧阵石硬压成形。"
    },
    {
      "id": "lm_qizhen_tingmai",
      "name": "听脉台",
      "x": 29,
      "y": 13,
      "desc": "听脉台压在第一重台地中央，初来者先在这里稳息，再被放进后面的主轴街里。"
    },
    {
      "id": "lm_qizhen_duxin",
      "name": "渡心堂",
      "x": 29,
      "y": 28,
      "desc": "渡心堂像一块嵌进街轴里的厚重石核，五行去向、归渡记录和继续上行的资格都在这里定。"
    },
    {
      "id": "lm_qizhen_baigong",
      "name": "百工巷",
      "x": 15,
      "y": 29,
      "desc": "西边不是一排整屋，而是炉棚、拆件院和补墙工坊互相咬着长出来，走进去总像在绕火。"
    },
    {
      "id": "lm_qizhen_jingqi",
      "name": "静气坊",
      "x": 43,
      "y": 29,
      "desc": "东侧静院借着水线半围成形，墙体和回廊都故意留得更松，让人一进去就先降躁气。"
    },
    {
      "id": "lm_qizhen_xingxiu",
      "name": "行修街",
      "x": 30,
      "y": 46,
      "desc": "南段摊巷和棚街彼此错开，摊布、灵材、残卷和雇工牌全是临时挂上去的，乱里有序。"
    },
    {
      "id": "lm_qizhen_old_ferry",
      "name": "旧渡口",
      "x": 46,
      "y": 52,
      "desc": "旧渡口沿着东水线一截一截外挑，木栈和石桩都是后补的，所以看起来总像还在慢慢长。"
    }
  ],
  "npcs": [
    {
      "id": "npc_lu_wei",
      "name": "闻脉师·陆微",
      "x": 29,
      "y": 13,
      "char": "闻",
      "color": "#c7d8b6",
      "dialogue": "你进了修士圈，不代表你站稳了。先把气海听清，再谈往哪一行里走。",
      "role": "quest_giver",
      "shopItems": [],
      "quests": []
    },
    {
      "id": "npc_su_jian",
      "name": "渡记官·苏简",
      "x": 29,
      "y": 28,
      "char": "记",
      "color": "#d7c89a",
      "dialogue": "栖真渡只记两种人：活着回来的，和还没把自己修坏的。你若两样都占，我这边就给你记一笔。",
      "role": "story",
      "shopItems": [],
      "quests": []
    },
    {
      "id": "npc_guo_huo",
      "name": "百工老匠·郭火",
      "x": 15,
      "y": 29,
      "char": "匠",
      "color": "#d89a63",
      "dialogue": "凡人的铁穿不到这一步了。要换练气家的东西，就拿对地方的料来，别拿一堆杂货糊弄我。",
      "role": "smith",
      "shopItems": [],
      "quests": []
    },
    {
      "id": "npc_xu_deng",
      "name": "静坊执事·许灯",
      "x": 43,
      "y": 29,
      "char": "静",
      "color": "#8fb7cf",
      "dialogue": "练气前段最怕的不是慢，是乱。你若脉息杂了、行功浮了，就先来静气坊坐一坐。",
      "role": "support",
      "shopItems": [],
      "quests": []
    },
    {
      "id": "npc_shi_gu",
      "name": "守坪人·石姑",
      "x": 29,
      "y": 10,
      "char": "守",
      "color": "#b7b0a4",
      "dialogue": "别急着问筑基。你连练气这只破碗都端不平，真把道基压下来，只会先把自己震裂。",
      "role": "guard",
      "shopItems": [],
      "quests": []
    },
    {
      "id": "npc_gu_hui",
      "name": "行修散商·顾回",
      "x": 30,
      "y": 46,
      "char": "商",
      "color": "#caa882",
      "dialogue": "五行料、残卷页、旧法器，全看你带回来什么。栖真渡这地方，东西新不新不重要，能不能保命才重要。",
      "role": "trader",
      "shopItems": [],
      "quests": []
    }
  ],
