  "landmarks": [
    {
      "id": "lm_cold_return_bridge",
      "name": "回渡雾桥",
      "x": 4,
      "y": 30,
      "desc": "寒汐泽最外圈唯一还算稳的落脚点，雾桥背后就是栖真渡，真撑不住时只能从这里退。"
    },
    {
      "id": "lm_cold_outer_bank",
      "name": "汊滩外湾",
      "x": 13,
      "y": 11,
      "desc": "外湾看着平缓，实则潮线一直在换，浅滩、冷泥和低雾把最外圈的路线切得并不老实。"
    },
    {
      "id": "lm_cold_twin_channels",
      "name": "双流水道",
      "x": 25,
      "y": 18,
      "desc": "两道主水路从这里开始真正缠成旋势，隔着水都能看见别处的路，却不是哪里都能一步跨过去。"
    },
    {
      "id": "lm_cold_sunken_fogway",
      "name": "沉雾曲桥",
      "x": 48,
      "y": 24,
      "desc": "桥道已经开始被寒雾和深水一圈圈卷弯，越靠里走，越像是整张图在主动把人往井心带。"
    },
    {
      "id": "lm_cold_wet_court",
      "name": "月井湿宫",
      "x": 36,
      "y": 41,
      "desc": "靠近寒核前的最后一圈湿宫残构，井堤、冷泥和旧桥桩把能走的线压得越来越窄。"
    },
    {
      "id": "lm_cold_core",
      "name": "月井寒核",
      "x": 28,
      "y": 27,
      "desc": "中心不再是普通沼地，而是一整片真正的寒沼冷核。能走到这里，才算碰到寒汐泽最核心的水行压力。"
    },
    {
      "id": "lm_cold_guizang_gate",
      "name": "归藏井门",
      "x": 34,
      "y": 30,
      "desc": "井下旧阵还留着一口能往更深处开的门，穿过去就是归藏脉窟外围的混行地带。"
    }
  ],
  "npcs": [
    {
      "id": "npc_cold_ferry_guide",
      "name": "雾桥摆渡客·沈汀",
      "x": 12,
      "y": 11,
      "char": "渡",
      "color": "#c7dff2",
      "dialogue": "寒汐泽不是比谁冲得快，是比谁先把杂气洗干净。你若连外湾的潮线都看不懂，进里圈只会越走越乱。",
      "role": "quest_hint",
      "shopItems": [],
      "quests": []
    },
    {
      "id": "npc_cold_vein_watcher",
      "name": "洗脉老修·冷槐",
      "x": 41,
      "y": 54,
      "char": "修",
      "color": "#a9c8e8",
      "dialogue": "月井最狠的地方不在冷，而在慢。你若一身杂气还想硬扛着往里压，最后只会把自己的气海洗成一摊乱流。",
      "role": "lore",
      "shopItems": [],
      "quests": []
    }
  ],
