{
  "name": "@mud/server-next",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "compile": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && pnpm --filter @mud/shared-next build && node ../../node_modules/.pnpm/node_modules/typescript/bin/tsc -p tsconfig.json",
    "build": "pnpm verify",
    "verify": "pnpm compile && pnpm smoke:all",
    "verify:with-db": "pnpm compile && pnpm smoke:all:with-db",
    "verify:replace-ready": "pnpm compile && node dist/tools/smoke-suite.js --case readiness-gate --case session --case runtime --case progression --case combat --case loot --case next-auth-bootstrap --case gm-next --case redeem-code --case monster-runtime --case monster-combat --case monster-ai --case monster-skill --case monster-reset --case monster-loot --case player-recovery --case player-respawn",
    "verify:proof:with-db": "pnpm compile && node dist/tools/smoke-suite.js --case next-auth-bootstrap-mainline --case next-auth-bootstrap-migration && node dist/tools/persistence-smoke.js",
    "verify:replace-ready:with-db": "pnpm compile && node dist/tools/smoke-suite.js --include-persistence",
    "start": "node dist/main.js",
    "start:dev": "pnpm compile && node scripts/dev-hot.js",
    "smoke:shadow": "pnpm compile && node dist/tools/shadow-smoke.js",
    "smoke:world-runtime-instance-tick-orchestration": "pnpm compile && node dist/tools/world-runtime-instance-tick-orchestration-smoke.js",
    "smoke:world-runtime-movement": "pnpm compile && node dist/tools/world-runtime-movement-smoke.js",
    "smoke:world-runtime-equipment": "pnpm compile && node dist/tools/world-runtime-equipment-smoke.js",
    "smoke:world-runtime-alchemy": "pnpm compile && node dist/tools/world-runtime-alchemy-smoke.js",
    "smoke:world-runtime-enhancement": "pnpm compile && node dist/tools/world-runtime-enhancement-smoke.js",
    "smoke:world-runtime-cultivation": "pnpm compile && node dist/tools/world-runtime-cultivation-smoke.js",
    "smoke:world-runtime-item-ground": "pnpm compile && node dist/tools/world-runtime-item-ground-smoke.js",
    "smoke:world-runtime-use-item": "pnpm compile && node dist/tools/world-runtime-use-item-smoke.js",
    "smoke:shadow:gm-database": "pnpm compile && node dist/tools/shadow-gm-database-proof.js",
    "smoke:all": "node dist/tools/smoke-suite.js",
    "smoke:all:with-db": "node dist/tools/smoke-suite.js --include-persistence",
    "smoke:runtime": "pnpm compile && node dist/tools/smoke-suite.js --case runtime",
    "smoke:persistence": "pnpm compile && node dist/tools/persistence-smoke.js",
    "smoke:gm-database": "pnpm compile && node dist/tools/gm-database-smoke.js",
    "smoke:gm-database:backup-persistence": "pnpm compile && node dist/tools/gm-database-backup-persistence-smoke.js",
    "smoke:afdian-persistence": "pnpm compile && node dist/tools/afdian-persistence-smoke.js",
    "smoke:gm-next": "pnpm compile && node dist/tools/smoke-suite.js --case gm-next",
    "smoke:readiness-gate": "pnpm compile && node dist/tools/smoke-suite.js --case readiness-gate",
    "smoke:next-auth-bootstrap": "pnpm compile && node dist/tools/smoke-suite.js --case next-auth-bootstrap",
    "smoke:next-auth-bootstrap:mainline": "pnpm compile && node dist/tools/smoke-suite.js --case next-auth-bootstrap-mainline",
    "smoke:next-auth-bootstrap:migration": "pnpm compile && node dist/tools/smoke-suite.js --case next-auth-bootstrap-migration",
    "smoke:session": "pnpm compile && node dist/tools/smoke-suite.js --case session",
    "smoke:progression": "pnpm compile && node dist/tools/smoke-suite.js --case progression",
    "smoke:combat": "pnpm compile && node dist/tools/smoke-suite.js --case combat",
    "smoke:redeem-code": "pnpm compile && node dist/tools/smoke-suite.js --case redeem-code",
    "smoke:monster-combat": "pnpm compile && node dist/tools/smoke-suite.js --case monster-combat",
    "smoke:monster-ai": "pnpm compile && node dist/tools/smoke-suite.js --case monster-ai",
    "smoke:monster-skill": "pnpm compile && node dist/tools/smoke-suite.js --case monster-skill",
    "smoke:monster-reset": "pnpm compile && node dist/tools/smoke-suite.js --case monster-reset",
    "smoke:player-recovery": "pnpm compile && node dist/tools/smoke-suite.js --case player-recovery",
    "smoke:player-respawn": "pnpm compile && node dist/tools/smoke-suite.js --case player-respawn",
    "smoke:loot": "pnpm compile && node dist/tools/smoke-suite.js --case loot",
    "smoke:monster-loot": "pnpm compile && node dist/tools/smoke-suite.js --case monster-loot",
    "smoke:monster-runtime": "pnpm compile && node dist/tools/smoke-suite.js --case monster-runtime",
    "migrate:legacy-next:once": "node src/tools/migrate-next-mainline-once.js --dry-run",
    "bench:tick": "pnpm compile && node dist/tools/bench-tick.js",
    "bench:sync": "pnpm compile && node dist/tools/bench-sync.js",
    "bench:combat": "pnpm compile && node dist/tools/bench-combat.js",
    "bench:first-package": "pnpm compile && node dist/tools/bench-first-package.js",
    "audit:next-protocol": "pnpm compile && node dist/tools/run-next-protocol-audit.js",
    "audit:content-map-consistency": "pnpm compile && node dist/tools/check-content-map-consistency.js",
    "audit:content-reference-consistency": "pnpm compile && node dist/tools/check-content-reference-consistency.js",
    "proof:next-content-map-sources": "pnpm compile && node dist/tools/prove-next-content-map-sources.js",
    "proof:next-runtime-network-no-legacy-source": "pnpm compile && node dist/tools/prove-next-runtime-network-no-legacy-source.js",
    "audit:legacy-boundaries": "pnpm compile && node dist/tools/audit/next-legacy-boundary-audit.js"
  },
  "dependencies": {
    "@mud/shared-next": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "typescript": "^5.3.0"
  }
}
