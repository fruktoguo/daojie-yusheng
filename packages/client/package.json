{
  "name": "@mud/client",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "proof:production-boundaries": "node ./scripts/check-client-production-boundaries.js",
    "generate:editor-catalog": "node ../../scripts/generate-editor-catalog.mjs --client=client --shared=shared",
    "generate:item-sources": "node ./scripts/generate-item-sources.mjs",
    "generate:building-catalog": "node ./scripts/generate-building-catalog.mjs",
    "generate:i18n": "node ./scripts/generate-i18n.mjs",
    "i18n:csv": "node ./scripts/i18n-csv.mjs",
    "prebuild": "pnpm --dir ../shared build && pnpm run generate:editor-catalog && pnpm run generate:item-sources && pnpm run generate:building-catalog && pnpm run generate:i18n",
    "dev": "vite",
    "dev:react-ui-prototype": "vite --open /react-ui-prototype.html",
    "build": "tsc --noEmit && vite build && pnpm run proof:production-boundaries",
    "verify:react-equipment": "node ./scripts/verify-react-equipment-panel.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mud/shared": "link:../shared",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io-client": "^4.7.0",
    "socket.io-msgpack-parser": "^3.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
