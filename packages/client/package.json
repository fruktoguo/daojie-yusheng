{
  "name": "@mud/client",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "generate:editor-catalog": "node ../../scripts/generate-editor-catalog.mjs --client=client --shared=shared",
    "generate:item-sources": "node ./scripts/generate-item-sources.mjs",
    "prebuild": "pnpm --filter @mud/shared build && pnpm run generate:editor-catalog && pnpm run generate:item-sources",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "socket.io-client": "^4.7.0",
    "@mud/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
